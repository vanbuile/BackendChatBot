PORT=5000
NODE_ENV=development

# MongoDB Configuration
# MongoDB Atlas (recommended)
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority&appName=<app-name>
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority&appName=<app-name>

# Gemini API Configuration
GEMINI_API_KEY=<your_gemini_api_key>
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BACKUP_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=<your_cloudinary_cloud_name>
CLOUDINARY_API_KEY=<your_cloudinary_api_key>
CLOUDINARY_API_SECRET=<your_cloudinary_api_secret>
# Unsigned upload preset (optional, creates faster uploads without API secret)
# Set this to your upload preset name created on Cloudinary dashboard
# Leave empty to use signed uploads (requires API secret)
CLOUDINARY_UPLOAD_PRESET=
# Cloudinary upload tuning
CLOUDINARY_UPLOAD_TIMEOUT_MS=120000
CLOUDINARY_UPLOAD_CONCURRENCY=2
UPLOAD_DEBUG=true
